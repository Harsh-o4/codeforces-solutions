# =========================================
# Ignore everything by default
# =========================================
*

# =========================================
# Allow directories
# =========================================
!*/

# =========================================
# Source files
# =========================================
!*.cpp
!*.cc
!*.c
!*.h
!*.hpp
!*.py
!*.java

# =========================================
# Text / config / docs
# =========================================
!*.md
!*.txt
!*.json
!*.yml
!*.yaml
!.gitignore

# =========================================
# VS Code
# =========================================
.vscode/

# =========================================
# JetBrains IDEs
# =========================================
.idea/
*.iml

# =========================================
# Vim
# =========================================
*.swp
*.swo
*~

# =========================================
# macOS / Windows junk
# =========================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================
# Build folders
# =========================================
build/
bin/
dist/
out/

# =========================================
# CMake
# =========================================
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile